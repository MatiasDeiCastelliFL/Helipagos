# Puerto donde corre la API Nest en local/Docker.
PORT=your_app_port

# false: ejecucion local | true: ejecucion dentro de Docker.
USE_DOCKER=your_use_docker_flag

# Host de base de datos para ejecucion local.
DB_HOST=your_local_db_host
# Host de base de datos cuando la app corre dentro de Docker.
DB_HOST_DOCKER=your_docker_db_host
# Puerto del servicio PostgreSQL.
DB_PORT=your_db_port
# Usuario que Nest usa para conectarse a la DB.
DB_USER=your_db_user
# Password del usuario de DB que usa Nest.
DB_PASSWORD=your_db_password
# Nombre de la base de datos de la aplicacion.
DB_NAME=your_db_name

# Credenciales/parametros del contenedor PostgreSQL.
# Usuario administrador creado al inicializar PostgreSQL.
POSTGRES_USER=your_postgres_user
# Password del usuario administrador de PostgreSQL.
POSTGRES_PASSWORD=your_postgres_password
# Base creada automaticamente al iniciar PostgreSQL.
POSTGRES_DB=your_postgres_db
# Solo para demo tecnica (sin password prompt en pgAdmin).
POSTGRES_HOST_AUTH_METHOD=your_postgres_host_auth_method

# Credenciales de acceso a la interfaz web de pgAdmin.
# Email para iniciar sesion en pgAdmin.
PGADMIN_DEFAULT_EMAIL=your_pgadmin_email
# Password para iniciar sesion en pgAdmin.
PGADMIN_DEFAULT_PASSWORD=your_pgadmin_password

# Config general de la app.
# Define si corre en modo productivo (true) o no (false).
PRODUCTION=your_production_flag
# Prefijo base de las rutas HTTP de la API.
URL_PREFIX=your_url_prefix
# URL base de entorno produccion para integraciones.
URL_PRODUCTION=your_production_url
# URL base de entorno sandbox/testing para integraciones.
URL_TEST=your_test_url
# Secreto para validar webhooks entrantes.
WEBHOOK_SECRET=your_webhook_secret
# Secreto para firmado/validacion de tokens.
TOKEN_SECRET=your_token_secret
